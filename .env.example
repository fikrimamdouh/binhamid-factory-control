# Supabase — configure in Vercel only.
# Secret values must remain REPLACE_IN_VERCEL_ONLY and must never be committed.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=factory-documents

# Direct PostgreSQL connection for backup tooling only. Keep outside browser code.
SUPABASE_DB_URL=
# A non-production target used only by the restore verification script.
RESTORE_DATABASE_URL=

# Public production URL for document verification and Telegram WebApp links.
PUBLIC_APP_URL=

# Browser/API gateway secret.
BINHAMID_ADMIN_TOKEN=

# Telegram bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_OWNER_ID=
TELEGRAM_WEBAPP_MAX_AGE_SECONDS=600

# AI: voice transcription, natural responses and document understanding.
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_TEXT_MODEL=gpt-5.4-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral

# Public business directory search.
GOOGLE_PLACES_API_KEY=

# Fleet GPS — Traccar is supported directly. Use token OR user/password.
GPS_PROVIDER=traccar
GPS_API_BASE_URL=
GPS_API_TOKEN=
GPS_API_USER=
GPS_API_PASSWORD=

# Scheduled briefs, employee reminders and operational alerts.
CRON_SECRET=
# GitHub Actions also needs BINHAMID_CRON_SECRET with the same value.
# BINHAMID_CRON_URL must contain the full production cron endpoint.

# Optional external HTML-to-PDF service.
PDF_API_URL=
PDF_API_KEY=

# Import safety.
MAX_IMPORT_FILE_BYTES=26214400

# Backup policy. BACKUP_ENCRYPTION_KEY should be a long random secret.
BACKUP_ENCRYPTION_KEY=
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PREFIX=backups
