# Supabase — server side only
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_IN_VERCEL_ONLY
SUPABASE_STORAGE_BUCKET=factory-documents

# Browser/API gateway token — choose a long random value
BINHAMID_ADMIN_TOKEN=REPLACE_WITH_LONG_RANDOM_SECRET

# Telegram bot
TELEGRAM_BOT_TOKEN=123456:REPLACE_IN_VERCEL_ONLY
TELEGRAM_WEBHOOK_SECRET=letters_numbers_dash_underscore_only
TELEGRAM_OWNER_ID=123456789

# AI: voice transcription, natural responses and document understanding
OPENAI_API_KEY=REPLACE_IN_VERCEL_ONLY
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_TEXT_MODEL=gpt-5.4-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral

# Public business directory search
GOOGLE_PLACES_API_KEY=REPLACE_IN_VERCEL_ONLY

# Fleet GPS — Traccar is supported directly
GPS_PROVIDER=traccar
GPS_API_BASE_URL=https://YOUR_TRACCAR_SERVER
GPS_API_TOKEN=
GPS_API_USER=
GPS_API_PASSWORD=

# Scheduled manager briefs and operational alerts
CRON_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# Optional external HTML-to-PDF service
PDF_API_URL=
PDF_API_KEY=
