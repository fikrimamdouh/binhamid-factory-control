{
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {"key":"Permissions-Policy","value":"unload=(self)"}
      ]
    },
    {
      "source": "/favicon.svg",
      "headers": [
        {"key":"Cache-Control","value":"public, max-age=86400"}
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {"key":"Cache-Control","value":"no-store"},
        {"key":"X-Content-Type-Options","value":"nosniff"},
        {"key":"Referrer-Policy","value":"same-origin"}
      ]
    }
  ]
}
