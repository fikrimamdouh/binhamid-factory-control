{
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {"source":"/api/admin/groups","destination":"/api/router?route=admin/groups"},
    {"source":"/api/admin/users","destination":"/api/router?route=admin/users"},
    {"source":"/api/dashboard","destination":"/api/router?route=dashboard"},
    {"source":"/api/conversations","destination":"/api/router?route=conversations"},
    {"source":"/api/operations","destination":"/api/router?route=operations"},
    {"source":"/api/reports","destination":"/api/router?route=reports"},
    {"source":"/api/documents/verify","destination":"/api/router?route=documents/verify"},
    {"source":"/api/imports/status","destination":"/api/router?route=imports/status"},
    {"source":"/api/imports/file","destination":"/api/router?route=imports/file"},
    {"source":"/api/state","destination":"/api/router?route=state"},
    {"source":"/api/system/database-readiness","destination":"/api/router?route=system/database-readiness"},
    {"source":"/api/system/status","destination":"/api/router?route=system/status"},
    {"source":"/api/telegram/register","destination":"/api/router?route=telegram/register"},
    {"source":"/api/telegram/status","destination":"/api/router?route=telegram/status"},
    {"source":"/api/telegram/test","destination":"/api/router?route=telegram/test"}
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {"key":"Permissions-Policy","value":"unload=(self), geolocation=(self)"}
      ]
    },
    {
      "source": "/",
      "headers": [
        {"key":"Cache-Control","value":"no-store, no-cache, must-revalidate, max-age=0"}
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {"key":"Cache-Control","value":"no-store, no-cache, must-revalidate, max-age=0"}
      ]
    },
    {
      "source": "/legacy.html",
      "headers": [
        {"key":"Cache-Control","value":"no-store, no-cache, must-revalidate, max-age=0"}
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {"key":"Cache-Control","value":"no-store, no-cache, must-revalidate, max-age=0"}
      ]
    },
    {
      "source": "/favicon.svg",
      "headers": [
        {"key":"Cache-Control","value":"public, max-age=86400"}
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {"key":"Cache-Control","value":"no-store"},
        {"key":"X-Content-Type-Options","value":"nosniff"},
        {"key":"Referrer-Policy","value":"same-origin"}
      ]
    }
  ]
}
